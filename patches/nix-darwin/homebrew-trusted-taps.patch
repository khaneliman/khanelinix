diff --git a/modules/homebrew.nix b/modules/homebrew.nix
index 4c5ab9807..37f3f5e5b 100644
--- a/modules/homebrew.nix
+++ b/modules/homebrew.nix
@@ -184,2 +184,2 @@ let
-        ++ optional (config.cleanup == "uninstall") "--cleanup"
-        ++ optional (config.cleanup == "zap") "--cleanup --zap"
+        ++ optional (config.cleanup == "uninstall") "--force-cleanup"
+        ++ optional (config.cleanup == "zap") "--zap --force-cleanup"
@@ -276,0 +277,14 @@ let
+      trusted = mkOption {
+        type = types.bool;
+        default = true;
+        example = false;
+        description = ''
+          Whether to trust this tap during {command}`brew bundle [install]`.
+
+          Recent Homebrew versions enable `HOMEBREW_REQUIRE_TAP_TRUST` by default, which refuses to
+          load formulae from non-official taps that haven't been trusted (aborting activation) and
+          silently skips their casks. This option emits Homebrew Bundle's `trusted: true` tap option
+          so non-official tap formulae and casks can be installed during activation. Official taps
+          are always trusted, so this has no effect on them.
+        '';
+      };
@@ -288,0 +303 @@ let
+          + optionalString config.trusted ", trusted: true"
@@ -962 +977 @@ in
-    system.activationScripts.homebrew.text = mkIf cfg.enable ''
+    system.activationScripts.homebrew.text = let toTrust = map (t: t.name) (filter (t: t.trusted) cfg.taps); in mkIf cfg.enable ''
@@ -965,0 +981,8 @@ in
+        ${optionalString (toTrust != [ ]) ''
+          PATH="${cfg.prefix}/bin:$PATH" \
+          sudo \
+            --preserve-env=PATH \
+            --user=${escapeShellArg cfg.user} \
+            --set-home \
+            ${cfg.prefix}/bin/brew trust --tap ${escapeShellArgs toTrust}
+        ''}
