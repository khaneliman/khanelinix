{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"additionalProperties": false,
	"required": ["verdict", "findings", "residual_risk"],
	"properties": {
		"verdict": {
			"type": "string",
			"enum": ["approved", "changes_requested", "blocked"]
		},
		"findings": {
			"type": "array",
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": [
					"severity",
					"path",
					"line",
					"summary",
					"rationale",
					"recommendation"
				],
				"properties": {
					"severity": {
						"type": "string",
						"enum": ["critical", "major", "minor", "suggestion"]
					},
					"path": { "type": ["string", "null"] },
					"line": { "type": ["integer", "null"], "minimum": 1 },
					"summary": { "type": "string" },
					"rationale": { "type": "string" },
					"recommendation": { "type": "string" }
				}
			}
		},
		"residual_risk": {
			"type": "array",
			"items": { "type": "string" }
		}
	}
}
